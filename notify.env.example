# notify.env — secrets & toggles for notify-dispatcher.sh
#
# The easiest way to fill this in is the guided wizard:   ./setup.sh
# Or copy it manually:
#   cp notify.env.example ~/.claude/notify.env && chmod 600 ~/.claude/notify.env
# NEVER commit your real notify.env (it holds secrets).

# --- Event toggles (apply to every channel) ---
NOTIFY_ON_NOTIFICATION="true"   # alert when Claude needs your input/permission
NOTIFY_ON_STOP="true"           # alert when Claude finishes a turn
STOP_SUMMARY="true"             # include a 1-line summary of what Claude just did
                                # (reads the session transcript; set "false" to omit)

# --- Slack (free; posts to a channel via an Incoming Webhook) ---
ENABLE_SLACK="true"
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"

# --- ntfy (free push app with a reliable alarm sound; great phone option) ---
# Install the "ntfy" app, subscribe to your topic, then enable here.
ENABLE_NTFY="false"
NTFY_TOPIC=""                   # your secret topic name, e.g. claude-alerts-7f3a9k
NTFY_SERVER="https://ntfy.sh"   # change only if you self-host ntfy
NTFY_TOKEN=""                   # only needed for protected/self-hosted servers

# --- Slack command approvals (optional two-way control; opt-in) ---
# Approve/deny tool calls from Slack while you're away. Requires a Slack *bot
# token* (not the webhook) with scopes chat:write + reactions:read, the bot
# invited to the channel, and the channel ID. Wire with ./install-approvals.sh,
# then arm/disarm with ./away.sh on|off. Disarmed = normal workflow (passthrough).
ENABLE_APPROVALS="false"
SLACK_BOT_TOKEN=""              # xoxb-...
SLACK_CHANNEL_ID=""             # e.g. C0123456789 (channel the bot is in)
APPROVAL_TIMEOUT="300"          # seconds to wait; no answer → denied (fail closed)
APPROVAL_POLL="4"               # seconds between reaction checks
APPROVE_EMOJI="white_check_mark"
DENY_EMOJI="x"
APPROVER_USER_IDS=""            # optional allowlist, e.g. "U0123 U0456" (blank = anyone in channel)

# --- Twilio SMS (optional; costs money, needs a Twilio account) ---
ENABLE_SMS="false"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
TO_PHONE_NUMBER=""
