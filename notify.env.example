# notify.env — secrets & toggles for notify-dispatcher.sh
#
# The easiest way to fill this in is the guided wizard:   ./setup.sh
# Or copy it manually:
#   cp notify.env.example ~/.claude/notify.env && chmod 600 ~/.claude/notify.env
# NEVER commit your real notify.env (it holds secrets).

# --- Event toggles (apply to every channel) ---
NOTIFY_ON_NOTIFICATION="true"   # alert when Claude needs your input/permission
NOTIFY_ON_STOP="true"           # alert when Claude finishes a turn

# --- Slack (free; posts to a channel via an Incoming Webhook) ---
ENABLE_SLACK="true"
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"

# --- ntfy (free push app with a reliable alarm sound; great phone option) ---
# Install the "ntfy" app, subscribe to your topic, then enable here.
ENABLE_NTFY="false"
NTFY_TOPIC=""                   # your secret topic name, e.g. claude-alerts-7f3a9k
NTFY_SERVER="https://ntfy.sh"   # change only if you self-host ntfy
NTFY_TOKEN=""                   # only needed for protected/self-hosted servers

# --- Twilio SMS (optional; costs money, needs a Twilio account) ---
ENABLE_SMS="false"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
TO_PHONE_NUMBER=""
