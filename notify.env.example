# notify.env — secrets & toggles for notify-dispatcher.sh
#
# Copy to ~/.claude/notify.env and fill in your values:
#   cp notify.env.example ~/.claude/notify.env && chmod 600 ~/.claude/notify.env
# (install.sh does this for you.)  NEVER commit your real notify.env.

# --- Slack ---
ENABLE_SLACK="true"
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"

# --- Event toggles ---
NOTIFY_ON_NOTIFICATION="true"   # fire when Claude needs your input/permission
NOTIFY_ON_STOP="true"           # fire when Claude finishes a turn

# --- SMS via Twilio (off by default; fill in + flip to enable) ---
ENABLE_SMS="false"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
TO_PHONE_NUMBER=""
